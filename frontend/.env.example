# Local dev (Vite). Prefer VITE_API_URL (backend origin, port 4000 locally).
# Leave empty to use smart fallbacks:
# - Desktop browser dev -> http://localhost:4000
# - Android emulator (Capacitor) -> http://10.0.2.2:4000
#
# For production / APK, set your public API origin (HTTPS recommended):
# VITE_API_URL=https://api.yourdomain.com
#
# Legacy fallback (only if VITE_API_URL is unset):
# VITE_API_BASE=https://api.yourdomain.com
VITE_API_URL=http://localhost:4000
VITE_API_BASE=

# WebRTC: звонки между *разными* сетями почти всегда нужен TURN (реле). STUN одного только недостаточно.
# Вариант A — JSON массив (как в https://developer.mozilla.org/en-US/docs/Web/API/RTCPeerConnection/RTCPeerConnection):
# VITE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]
#
# Вариант B — отдельные переменные (URLs через запятую):
# VITE_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# VITE_TURN_USERNAME=user
# VITE_TURN_CREDENTIAL=pass
