# Local dev (Vite). Prefer VITE_API_URL (backend origin, port 4000 locally).
# Leave empty to use smart fallbacks:
# - Desktop browser dev -> http://localhost:4000
# - Android emulator (Capacitor) -> http://10.0.2.2:4000
#
# For production / APK, set your public API origin (HTTPS recommended):
# VITE_API_URL=https://api.yourdomain.com
#
# Legacy fallback (only if VITE_API_URL is unset):
# VITE_API_BASE=https://api.yourdomain.com
VITE_API_URL=http://localhost:4000
VITE_API_BASE=
