# Copy to .env.production.local before building for devices / LAN / ngrok.
# API + Socket.io use this origin (HTTPS recommended in production).
#
# Preferred:
# VITE_API_URL=https://api.yourdomain.com
#
# Legacy (only if VITE_API_URL is empty):
# VITE_API_BASE=https://api.yourdomain.com
#
# Without a URL, production builds default to http://localhost:4000 (wrong on a phone).
VITE_API_URL=
VITE_API_BASE=
