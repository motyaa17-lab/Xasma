# Copy to frontend/.env.production for release builds (committed or CI).
# Optional: frontend/.env.production.local for machine-specific overrides — that file
# overrides .env.production for `vite build`, so a LAN URL here breaks APKs off that network.
#
# API + Socket.io use this origin (HTTPS recommended in production).
#
# Preferred:
# VITE_API_URL=https://api.yourdomain.com
#
# Legacy (only if VITE_API_URL is empty):
# VITE_API_BASE=https://api.yourdomain.com
#
# Without a URL, production builds have no API base (configure env before shipping).
VITE_API_URL=
VITE_API_BASE=
